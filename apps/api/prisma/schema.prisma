generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Peran {
  id              String          @id @default(uuid()) @db.Uuid
  kode            String          @unique @db.VarChar(50)
  nama            String          @unique @db.VarChar(100)
  deskripsi       String?         @db.Text
  is_aktif        Boolean         @default(true)
  dibuat_pada     DateTime        @default(now()) @db.Timestamptz(6)
  diperbarui_pada DateTime        @updatedAt @db.Timestamptz(6)

  pengguna_peran  PenggunaPeran[]

  @@map("peran")
}

model Pengguna {
  id                  String          @id @default(uuid()) @db.Uuid
  email               String?         @unique @db.VarChar(255)
  username            String?         @unique @db.VarChar(100)
  kata_sandi_hash     String          @db.Text
  nama_tampilan       String          @db.VarChar(150)
  status              String          @default("AKTIF") @db.VarChar(30)
  terakhir_login_pada DateTime?       @db.Timestamptz(6)
  dibuat_pada         DateTime        @default(now()) @db.Timestamptz(6)
  diperbarui_pada     DateTime        @updatedAt @db.Timestamptz(6)
  dihapus_pada        DateTime?       @db.Timestamptz(6)

  pengguna_peran      PenggunaPeran[]
  warga               Warga?

  @@map("pengguna")
}

model PenggunaPeran {
  id              String   @id @default(uuid()) @db.Uuid
  pengguna_id     String   @db.Uuid
  peran_id        String   @db.Uuid
  diberi_pada     DateTime @default(now()) @db.Timestamptz(6)
  dibuat_pada     DateTime @default(now()) @db.Timestamptz(6)
  diperbarui_pada DateTime @updatedAt @db.Timestamptz(6)

  pengguna Pengguna @relation(fields: [pengguna_id], references: [id], onDelete: Cascade)
  peran    Peran    @relation(fields: [peran_id], references: [id], onDelete: Restrict)

  @@unique([pengguna_id, peran_id])
  @@index([peran_id])
  @@map("pengguna_peran")
}

model Warga {
  id               String    @id @default(uuid()) @db.Uuid
  pengguna_id      String?   @db.Uuid
  nomor_identitas  String?   @db.VarChar(100)
  nama_lengkap     String    @db.VarChar(200)
  jenis_kelamin    String?   @db.VarChar(20)
  tempat_lahir     String?   @db.VarChar(100)
  tanggal_lahir    DateTime? @db.Date
  nomor_telepon    String?   @db.VarChar(30)
  email            String?   @db.VarChar(255)
  status           String    @default("AKTIF") @db.VarChar(30)
  catatan          String?   @db.VarChar(500)
  dibuat_pada      DateTime  @default(now()) @db.Timestamptz(6)
  diperbarui_pada  DateTime  @updatedAt @db.Timestamptz(6)
  dihapus_pada     DateTime? @db.Timestamptz(6)

  pengguna Pengguna? @relation(fields: [pengguna_id], references: [id], onDelete: SetNull)

  @@unique([pengguna_id])
  @@index([nama_lengkap])
  @@index([status])
  @@map("warga")
}
